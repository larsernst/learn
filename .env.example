# ── Ports ───────────────────────────────────────────────────
# Web-Port der Next.js-App (Host und Container).
WEB_PORT=3000
# Port der PostgreSQL-Datenbank (Host und Container).
POSTGRES_PORT=5432

# ── Geheimnisse ─────────────────────────────────────────────
# Bitte durch lange, zufaellige Geheimnisse ersetzen!
JWT_SECRET="bitte-durch-ein-langes-zufaelliges-geheimnis-ersetzen"
NEXTAUTH_SECRET="bitte-durch-ein-langes-zufaelliges-geheimnis-ersetzen"

# ── Session-Cookie ──────────────────────────────────────────
# Nur auf "true" setzen, wenn die App ausschliesslich ueber HTTPS
# ausgeliefert wird. Bei HTTP (z. B. http://domain:3002) MUSS das
# "false" bleiben, sonst speichert der Browser das Cookie nicht
# und Login schlaegt still fehl.
SESSION_COOKIE_SECURE="false"

# ── Datenbank ───────────────────────────────────────────────
# Wird von docker-compose bereitgestellt. Fuer lokale Entwicklung ohne Docker
# an deine PostgreSQL-Instanz anpassen (Port = POSTGRES_PORT).
DATABASE_URL="postgresql://lernapp:lernapp@localhost:5432/lernapp?schema=public"

# ── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="BS Lern-App"