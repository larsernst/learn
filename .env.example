# ── Ports ───────────────────────────────────────────────────
# Web-Port der Next.js-App (Host und Container).
WEB_PORT=3000
# Port der PostgreSQL-Datenbank (Host und Container).
POSTGRES_PORT=5432

# ── Geheimnisse ─────────────────────────────────────────────
# Bitte durch ein langes, zufaelliges Geheimnis ersetzen!
# (Beim Start validiert src/lib/env.ts Laenge und Platzhalter.)
JWT_SECRET="bitte-durch-ein-langes-zufaelliges-geheimnis-ersetzen"

# ── Session-Cookie ──────────────────────────────────────────
# Nur auf "true" setzen, wenn die App ausschliesslich ueber HTTPS
# ausgeliefert wird. Bei HTTP (z. B. http://domain:3002) MUSS das
# "false" bleiben, sonst speichert der Browser das Cookie nicht
# und Login schlaegt still fehl.
SESSION_COOKIE_SECURE="false"

# ── Sicherheit ──────────────────────────────────────────────
# Erlaubte Origins fuer Cross-Origin-POSTs (CSRF-Schutz), kommasepariert.
# Bei gleicher Herkunft leer lassen. Beispiel:
#   ALLOWED_ORIGINS="https://bs.example.org,https://www.example.org"
ALLOWED_ORIGINS=""

# ── Datenbank ───────────────────────────────────────────────
# Wird von docker-compose bereitgestellt. Fuer lokale Entwicklung ohne Docker
# an deine PostgreSQL-Instanz anpassen (Port = POSTGRES_PORT).
DATABASE_URL="postgresql://lernapp:lernapp@localhost:${POSTGRES_PORT}/lernapp?schema=public"

# ── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="Lern-App"

# Demo-/Beispiel-Inhalte (zwei Kurse mit 131 Fragen aus dem Fragenkatalog)
# beim Container-Start seeden. Standard: "false" – die App startet ohne
# vorbelegte Kurse; Inhalte werden von Editoren/Admins erstellt.
# Fuer lokale Entwicklung mit Beispielinhalt: "true" setzen ODER einmalig
# manuell `npm run db:seed` ausfuehren.
SEED_DEMO_CONTENT="false"

# ── Code-Aufgaben (Phase 4) ─────────────────────────────────
# Auto-Bewertung von Code-Aufgaben via Judge0. Optional – wenn JUDGE0_ENABLED
# auf "false" steht (default), werden Code-Aufgaben serverseitig abgelehnt
# und in der Editor-UI nicht angeboten. Judge0 wird via docker-compose-Profil
# 'code' gestartet: `docker compose --profile code up`.
#   JUDGE0_URL: interne URL des Judge0-Servers (im Docker-Netzwerk).
#   JUDGE0_TOKEN: langes Zufalls-Token, das auch in den Judge0-Containern
#                 gesetzt werden muss (docker-compose.yml). Wird als
#                 Authorization-Header mitgeschickt.
JUDGE0_ENABLED="false"
JUDGE0_URL="http://judge0-server:2358"
JUDGE0_TOKEN="bitte-durch-ein-langes-zufaelliges-token-ersetzen"

# ── Admin ───────────────────────────────────────────────────
# Admins werden nicht mehr ueber ein Token, sondern ueber Rollen
# in der Datenbank verwaltet. Den ersten Admin legt man nach dem
# ersten Login einmalig an:
#   npm run db:make-admin -- --email user@example.com
# Weitere Admins koennen dann in der Admin-Oberflaeche (/admin/nutzer)
# ernannt werden.