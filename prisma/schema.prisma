generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String        @id @default(cuid())
  email             String        @unique
  name              String
  passwordHash      String
  mcqEnabled        Boolean       @default(true)
  simpleGrading     Boolean       @default(false)
  newQuestionsFirst Boolean       @default(true)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  reviews           Review[]
  events            ReviewEvent[]
  roles             UserRole[]
  ownedCourses      Course[]      @relation("CourseOwner")
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  role      String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, role])
  @@index([userId])
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Course {
  id          String     @id
  slug        String     @unique
  title       String
  description String
  order       Int        @default(0)
  ownerId     String?
  owner       User?      @relation("CourseOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  status      String     @default("published")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  questions   Question[]
  chapters    Chapter[]
}

model Chapter {
  id          String     @id @default(cuid())
  courseId    String
  course      Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  slug        String
  title       String
  description String?
  order       Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  questions   Question[]

  @@unique([courseId, slug])
  @@index([courseId, order])
}

model Question {
  id           String        @id
  courseId     String?
  course       Course?       @relation(fields: [courseId], references: [id])
  chapter      Int
  chapterTitle String
  chapterId    String?
  chapterRef   Chapter?      @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  question     String
  answer       String
  sourceRef    String
  confidence   String?
  taskType     String?
  payload      Json?
  createdAt    DateTime      @default(now())
  reviews      Review[]
  events       ReviewEvent[]
}

model Review {
  id             String    @id @default(cuid())
  userId         String
  questionId     String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  question       Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  easeFactor     Float     @default(2.5)
  intervalDays   Int       @default(0)
  repetitions    Int       @default(0)
  lapses         Int       @default(0)
  dueAt          DateTime  @default(now())
  lastReviewedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([userId, questionId])
  @@index([userId, dueAt])
}

model ReviewEvent {
  id         String   @id @default(cuid())
  userId     String
  questionId String
  grade      String
  correct    Boolean?
  at         DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([userId, at])
  @@index([userId, questionId])
}
